{
  "permissions": {
    "deny": [
      "Bash(sudo:*)",
      "Read(.env)",
      "Write(.env)",
      "Edit(.env)"
    ],
    "defaultMode": "acceptEdits",
    "allow": [
      "WebFetch(domain:registry.npmjs.org)",
      "Read(/Users/mot/.npm)",
      "Write(/Users/mot/.npm)",
      "Bash(npm create vite@latest *)",
      "Bash(npm install *)",
      "Bash(npm install)",
      "Bash(cp *)",
      "Bash(mkdir *)",
      "Bash(cat *)",
      "Read(/Users/mot/Documents/fcc-repos/freecodecamp-games/**/*)",
      "Write(/Users/mot/Documents/fcc-repos/freecodecamp-games/**/*)",
      "Edit(/Users/mot/Documents/fcc-repos/freecodecamp-games/**/*)"
    ]
  },
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": ["registry.npmjs.org"],
      "allowUnixSockets": [],
      "allowAllUnixSockets": false,
      "allowLocalBinding": false
    }
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      ""
    ]
  }
}
